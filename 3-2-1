#include <iostream>
#include <vector>
#include <cmath>
#include <fstream>
#include <iomanip>
#include <chrono>
#include <sstream>  // Pour to_string

using namespace std;

class SLAESolver {
private:
    vector<vector<double>> A;
    vector<double> b;
    int n;
    
public:
    SLAESolver(vector<vector<double>> matrix, vector<double> constants) 
        : A(matrix), b(constants) {
        n = A.size();
    }
    
    double computeNorm(const vector<double>& x) {
        double sum = 0;
        for (int i = 0; i < n; i++) {
            double residual = b[i];
            for (int j = 0; j < n; j++) {
                residual -= A[i][j] * x[j];
            }
            sum += residual * residual;
        }
        return sqrt(sum);
    }
    
    // Méthode de Jacobi - retourne la solution et les résidus
    vector<double> jacobiMethod(vector<double> x0, vector<double>& residuals,
                                double tolerance = 1e-6,
                                int maxIterations = 1000) {
        vector<double> x = x0;
        vector<double> x_new(n, 0);
        residuals.clear();
        
        for (int iter = 0; iter < maxIterations; iter++) {
            for (int i = 0; i < n; i++) {
                double sum = 0;
                for (int j = 0; j < n; j++) {
                    if (j != i) {
                        sum += A[i][j] * x[j];
                    }
                }
                x_new[i] = (b[i] - sum) / A[i][i];
            }
            
            double norm = computeNorm(x_new);
            residuals.push_back(norm);
            
            if (norm < tolerance) {
                cout << "Méthode de Jacobi a convergé après " << iter + 1 
                     << " itérations" << endl;
                return x_new;
            }
            
            x = x_new;
        }
        
        cout << "Méthode de Jacobi: nombre maximum d'itérations atteint" << endl;
        return x;
    }
    
    // Méthode de Gauss-Seidel - retourne la solution et les résidus
    vector<double> gaussSeidelMethod(vector<double> x0, vector<double>& residuals,
                                     double tolerance = 1e-6,
                                     int maxIterations = 1000) {
        vector<double> x = x0;
        residuals.clear();
        
        for (int iter = 0; iter < maxIterations; iter++) {
            vector<double> x_old = x;
            
            for (int i = 0; i < n; i++) {
                double sum1 = 0, sum2 = 0;
                for (int j = 0; j < i; j++) {
                    sum1 += A[i][j] * x[j];
                }
                for (int j = i + 1; j < n; j++) {
                    sum2 += A[i][j] * x_old[j];
                }
                x[i] = (b[i] - sum1 - sum2) / A[i][i];
            }
            
            double norm = computeNorm(x);
            residuals.push_back(norm);
            
            if (norm < tolerance) {
                cout << "Méthode de Gauss-Seidel a convergé après " << iter + 1 
                     << " itérations" << endl;
                return x;
            }
        }
        
        cout << "Méthode de Gauss-Seidel: nombre maximum d'itérations atteint" << endl;
        return x;
    }
    
    void printSolution(const vector<double>& x, const string& methodName) {
        cout << "\n" << methodName << " - Solution:" << endl;
        for (int i = 0; i < n; i++) {
            cout << "x[" << i << "] = " << fixed << setprecision(8) << x[i] << endl;
        }
    }
    
    void exportToCSV(const vector<double>& residualsJacobi, 
                    const vector<double>& residualsGS,
                    const string& filename) {
        ofstream file(filename);
        if (!file.is_open()) {
            cerr << "Erreur: impossible d'ouvrir le fichier " << filename << endl;
            return;
        }
        
        file << "Iteration,Jacobi,GaussSeidel\n";
        int maxSize = max(residualsJacobi.size(), residualsGS.size());
        
        for (int i = 0; i < maxSize; i++) {
            file << i + 1 << ",";
            if (i < (int)residualsJacobi.size())
                file << residualsJacobi[i];
            else
                file << "";
            
            file << ",";
            
            if (i < (int)residualsGS.size())
                file << residualsGS[i];
            else
                file << "";
            
            file << "\n";
        }
        
        file.close();
        cout << "\nDonnées exportées vers " << filename << endl;
    }
};

// Fonction pour convertir int en string (compatible C++98/11)
string intToString(int n) {
    ostringstream oss;
    oss << n;
    return oss.str();
}

SLAESolver createTestSystem(int size) {
    vector<vector<double>> A(size, vector<double>(size, 0));
    vector<double> b(size, 0);
    
    for (int i = 0; i < size; i++) {
        for (int j = 0; j < size; j++) {
            if (i == j) {
                A[i][j] = 10.0;
            } else {
                A[i][j] = 1.0;
            }
        }
        b[i] = 10.0 * (i + 1);
    }
    
    return SLAESolver(A, b);
}

SLAESolver createCustomSystem() {
    vector<vector<double>> A = {
        {4, 1, 1},
        {1, 5, 2},
        {2, 1, 6}
    };
    
    vector<double> b = {7, 9, 10};
    
    return SLAESolver(A, b);
}

int main() {
    cout << "=== RÉSOLUTION DE SLAE PAR MÉTHODES ITÉRATIVES ===" << endl;
    cout << "Méthodes: Jacobi et Gauss-Seidel\n" << endl;
    
    int choice;
    cout << "Choisissez le système à résoudre:" << endl;
    cout << "1. Système test (diagonal dominant, taille 4)" << endl;
    cout << "2. Système personnalisé (3 équations)" << endl;
    cout << "3. Système défini par l'utilisateur" << endl;
    cout << "Votre choix: ";
    cin >> choice;
    
    SLAESolver solver = createTestSystem(4);
    
    if (choice == 2) {
        solver = createCustomSystem();
    } else if (choice == 3) {
        int size;
        cout << "Entrez la taille du système: ";
        cin >> size;
        
        vector<vector<double>> A(size, vector<double>(size));
        vector<double> b(size);
        
        cout << "Entrez la matrice A (" << size << "x" << size << "):" << endl;
        for (int i = 0; i < size; i++) {
            for (int j = 0; j < size; j++) {
                cout << "A[" << i << "][" << j << "] = ";
                cin >> A[i][j];
            }
        }
        
        cout << "Entrez le vecteur b:" << endl;
        for (int i = 0; i < size; i++) {
            cout << "b[" << i << "] = ";
            cin >> b[i];
        }
        
        solver = SLAESolver(A, b);
    }
    
    // Déterminer la taille du système pour les approximations initiales
    int systemSize = (choice == 2) ? 3 : 4;
    
    vector<vector<double>> initialGuesses;
    if (choice == 2) {
        vector<double> guess1(3, 0);
        vector<double> guess2(3, 1);
        vector<double> guess3(3, 10);
        initialGuesses.push_back(guess1);
        initialGuesses.push_back(guess2);
        initialGuesses.push_back(guess3);
    } else {
        vector<double> guess1(4, 0);
        vector<double> guess2(4, 1);
        vector<double> guess3(4, 10);
        initialGuesses.push_back(guess1);
        initialGuesses.push_back(guess2);
        initialGuesses.push_back(guess3);
    }
    
    cout << "\n" << string(50, '=') << endl;
    
    // Variables pour stocker les résultats
    vector<double> solutionJacobi, solutionGS;
    vector<double> residualsJacobi, residualsGS;
    
    // Pour chaque condition initiale
    for (int k = 0; k < (int)initialGuesses.size(); k++) {
        vector<double> x0 = initialGuesses[k];
        
        cout << "\n--- Approximation initiale: ";
        for (int i = 0; i < (int)x0.size(); i++) {
            cout << x0[i] << " ";
        }
        cout << "---" << endl;
        
        // Méthode de Jacobi
        solutionJacobi = solver.jacobiMethod(x0, residualsJacobi);
        solver.printSolution(solutionJacobi, "Jacobi");
        if (!residualsJacobi.empty()) {
            cout << "Norme finale du résidu: " << residualsJacobi.back() << endl;
        }
        
        // Méthode de Gauss-Seidel
        solutionGS = solver.gaussSeidelMethod(x0, residualsGS);
        solver.printSolution(solutionGS, "Gauss-Seidel");
        if (!residualsGS.empty()) {
            cout << "Norme finale du résidu: " << residualsGS.back() << endl;
        }
        
        // Exportation des données pour graphique
        string filename = "residuals_init" + intToString(k) + ".csv";
        solver.exportToCSV(residualsJacobi, residualsGS, filename);
        
        cout << string(50, '-') << endl;
    }
    
    cout << "\nPour visualiser les graphiques:" << endl;
    cout << "1. Ouvrez les fichiers CSV générés dans Excel/Google Sheets" << endl;
    cout << "2. Créez un graphique avec l'itération en abscisse et le résidu en ordonnée" << endl;
    cout << "3. Utilisez une échelle logarithmique pour mieux visualiser la convergence" << endl;
    
    return 0;
}
